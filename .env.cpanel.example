# Environment Configuration for cPanel Deployment
# Copy this file to .env and update values before building

# Admin panel login password
VITE_ADMIN_PASSWORD=admin123

# Supabase configuration (optional - for image uploads & database)
# If not set, admin panel will use localStorage (offline mode)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Site configuration
VITE_SITE_TITLE=Portfolio
VITE_SITE_DESCRIPTION=Full-stack developer portfolio
