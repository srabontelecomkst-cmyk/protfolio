{
  "framework": null,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node",
      "config": {
        "buildCommand": "pnpm run build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(assets/.*)",
      "dest": "/dist/spa/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/server/node-build.mjs"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}

